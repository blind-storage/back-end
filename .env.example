# == Application ==
PORT=3000

# == Database ==
POSTGRES_USER=blind_user
POSTGRES_PASSWORD=blind_password
POSTGRES_DB=blind_storage
POSTGRES_PORT=5432

# == Prisma ==
DATABASE_URL="postgresql://blind_user:blind_password@localhost:5432/blind_storage?schema=public"

# == Auth ==

# Google OAuth2
GOOGLE_CLIENT_ID=google-client-id
GOOGLE_SECRET=google-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
# Connexion du stockage Google Drive (scopes drive.file + offline) — redirect séparé du login
GOOGLE_DRIVE_CALLBACK_URL=http://localhost:3000/cloud-storage/google-drive/callback

# Rezel
REZEL_CLIENT_ID=rezel-client-id
REZEL_SECRET=rezel-secret
REZEL_CALLBACK_URL=http://localhost:3000/auth/rezel/callback
REZEL_ISSUER_URL=https://rezel-issuer.com
REZEL_AUTH_URL=https://rezel-issuer.com/auth
REZEL_TOKEN_URL=https://rezel-issuer.com/token
REZEL_USERINFO_URL=https://rezel-issuer.com/userinfo

# Dropbox OAuth2
DROPBOX_CLIENT_ID=dropbox-client-id
DROPBOX_CLIENT_SECRET=dropbox-client-secret
DROPBOX_CALLBACK_URL=http://localhost:3000/auth/dropbox/callback
# Connexion du stockage Dropbox (scopes files.content.* + offline) — redirect séparé du login
DROPBOX_STORAGE_CALLBACK_URL=http://localhost:3000/cloud-storage/dropbox/callback

# JWT
JWT_SECRET=jwt-secret

# Cores
FRONTEND_URL=https://blind-storage.rezel.net

# Session
SESSION_SECRET=secret