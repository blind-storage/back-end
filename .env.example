# == Application ==
PORT=3000

# == Database ==
POSTGRES_USER=blind_user
POSTGRES_PASSWORD=blind_password
POSTGRES_DB=blind_storage
POSTGRES_PORT=5432

# == Prisma ==
DATABASE_URL="postgresql://blind_user:blind_password@localhost:5432/blind_storage?schema=public"

# == Auth ==

# Google OAuth2
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Rezel
REZEL_CLIENT_ID=your-rezel-client-id
REZEL_SECRET=your-rezel-client-secret
REZEL_CALLBACK_URL=http://localhost:8000/auth/rezel/callback
REZEL_ISSUER_URL=https://auth.garezeldap.rezel.net/application/o/
REZEL_AUTH_URL=https://auth.garezeldap.rezel.net/application/o/authorize/
REZEL_TOKEN_URL=https://auth.garezeldap.rezel.net/application/o/token/
REZEL_USERINFO_URL=https://auth.garezeldap.rezel.net/application/o/userinfo/

# Dropbox OAuth2
DROPBOX_CLIENT_ID=your-dropbox-client-id
DROPBOX_CLIENT_SECRET=your-dropbox-client-secret
DROPBOX_CALLBACK_URL=http://localhost:3000/auth/dropbox/callback

# JWT
JWT_SECRET=replace-with-a-long-random-secret

# Session
SESSION_SECRET=replace-with-a-long-random-secret

# Cores
FRONTEND_URL=http://localhost:8000
