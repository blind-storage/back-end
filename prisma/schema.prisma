// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  username       String   @unique
  role           Role     @default(USER)
  auth_hash      String?  // null si auth uniquement via OIDC (sans mot de passe)
  salt_mp        String?  // salt pour la dérivation du mot de passe maître
  salt_rc        String?  // salt pour la dérivation du code de récupération
  pub_key        String   @unique
  priv_key_enc_1 String   @unique
  priv_key_enc_2 String   @unique
  tree_enc_key   String   @unique
  sign_pub_key              String? @unique
  sign_priv_key_enc_1       String? @unique
  sign_priv_key_enc_2       String? @unique
  key_certificate           Json?
  key_certificate_signature String?
  key_fingerprint           String? @unique

  totpSecret     String?
  totpEnabled    Boolean  @default(false)

  oidcConnections   OidcConnection[]
  totpRecoveryCodes TotpRecoveryCode[]
  userTree          UserTree?
  files             File[]
  folders           Folder[]
  permissions       FilePermission[] @relation("UserPermissions")
  grantedPerms      FilePermission[] @relation("GrantedPermissions")
  editedVersions    FileVersion[]
}

// Arborescence virtuelle de dossiers (métadonnées only). Le contenu des fichiers
// reste chiffré côté client ; ce modèle ne sert qu'à organiser/naviguer.
model Folder {
  id         String   @id @default(uuid())
  ownerId    String
  owner      User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name       String
  parentId   String?
  parent     Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children   Folder[] @relation("FolderTree")
  files      File[]
  providerId String?  // ID du dossier miroir chez le provider (Google Drive)
  provider   String   @default("google-drive")
  createdAt  DateTime @default(now())

  @@index([ownerId])
  @@index([parentId])
  @@index([ownerId, provider])
}

model TotpRecoveryCode {
  id        String    @id @default(uuid())
  userId    String
  codeHash  String
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Un utilisateur peut avoir plusieurs connexions OIDC (Google, Rezel, etc.)
model OidcConnection {
  id             String       @id @default(uuid())
  userId         String
  provider       OidcProvider
  providerUserId String
  email          String?

  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  driveScope     Boolean      @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@unique([userId, provider])
  @@index([userId])
}

enum Role {
  USER
  ADMIN
}

enum OidcProvider {
  GOOGLE
  REZEL
  DROPBOX
}

model UserTree {
  id                  String @id @default(uuid())
  userId              String @unique
  user                User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  encrypted_structure String
  signature           String
}

model File {
  id          String           @id @default(uuid())
  createdAt   DateTime         @default(now())
  cloud_data  Json
  ownerId     String
  owner       User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  folderId    String?
  folder      Folder?          @relation(fields: [folderId], references: [id], onDelete: SetNull)
  permissions FilePermission[]
  versions    FileVersion[]

  @@index([ownerId])
  @@index([folderId])
}

model FilePermission {
  id          String   @id @default(uuid())
  fileId      String
  userId      String
  enc_fek     String
  read        Boolean  @default(false)
  write       Boolean  @default(false)
  manage      Boolean  @default(false)
  grantedById String
  grantedAt   DateTime @default(now())

  file      File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user      User @relation("UserPermissions", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User @relation("GrantedPermissions", fields: [grantedById], references: [id], onDelete: Cascade)

  @@unique([fileId, userId])
}

model FileVersion {
  id         String   @id @default(uuid())
  fileId     String
  version    Int
  createdAt  DateTime @default(now())
  signature  String
  editedById String

  file   File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  editor User @relation(fields: [editedById], references: [id], onDelete: Cascade)

  @@unique([fileId, version])
}

model RevokedCertificate {
  id          String   @id @default(uuid())
  fingerprint String   @unique
  reason      String
  revokedAt   DateTime @default(now())
}
